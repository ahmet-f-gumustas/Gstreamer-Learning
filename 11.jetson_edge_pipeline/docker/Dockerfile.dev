# x86 development image: CUDA 12.4 + TensorRT 10 + GStreamer 1.20 + OpenCV
# Build:  docker build -f docker/Dockerfile.dev -t edge-dev:x86 .
# Run:    docker run --rm -it --gpus all -v $(pwd):/work edge-dev:x86

FROM nvcr.io/nvidia/tensorrt:24.04-py3

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential cmake ninja-build git pkg-config \
        libgstreamer1.0-dev libgstreamer-plugins-base1.0-dev \
        libgstreamer-plugins-bad1.0-dev \
        gstreamer1.0-plugins-base gstreamer1.0-plugins-good \
        gstreamer1.0-plugins-bad  gstreamer1.0-plugins-ugly \
        gstreamer1.0-libav        gstreamer1.0-tools \
        libopencv-dev libyaml-cpp-dev \
        libaravis-0.8-dev gstreamer1.0-aravis \
        v4l-utils python3-pip \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir \
        numpy onnx onnxruntime-gpu opencv-python ultralytics pycuda

WORKDIR /work
CMD ["/bin/bash"]
